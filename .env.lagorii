UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN_HERE
GOOGLE_MAPS_KEY=YOUR_GOOGLE_KEY_HERE
INVALIDATE_SECRET=lagorii-pick-a-long-random-string
ALLOWED_ORIGINS=https://lagorii.com,https://lagorii-kids.myshopify.com
