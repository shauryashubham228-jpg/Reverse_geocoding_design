{
  "name": "lagorii-geo-api",
  "version": "1.0.0",
  "description": "Server-side geolocation caching API for Lagorii Shopify store",
  "private": true,
  "engines": { "node": ">=18" },
  "scripts": {
    "dev":              "vercel dev",
    "deploy":           "vercel --prod",
    "test":             "jest tests/unit.test.js --no-coverage",
    "test:integration": "jest tests/integration.test.js --no-coverage --testTimeout=30000",
    "test:load":        "node tests/load.test.js"
  },
  "dependencies": {
    "@upstash/redis": "^1.28.0"
  },
  "devDependencies": {
    "autocannon": "^7.14.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node"
  }
}
